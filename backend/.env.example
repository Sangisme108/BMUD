PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=abnormal_login_detection
DB_SSL=false
# Optional for providers that give you a custom CA certificate:
DB_SSL_CA_PATH=
JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
OTP_SECRET=replace_with_a_third_long_random_secret
NODE_ENV=development
TRUST_PROXY_HOPS=1
CORS_ORIGINS=
AUTH_ACCOUNT_FAILURE_LIMIT=5
AUTH_EMAIL_IP_FAILURE_LIMIT=5
AUTH_IP_FAILURE_LIMIT=25
ENABLE_DEBUG_OTP=false
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=BMUD <onboarding@resend.dev>
RESEND_API_KEY=
EMAIL_CONNECTION_TIMEOUT_MS=30000
EMAIL_GREETING_TIMEOUT_MS=30000
EMAIL_SOCKET_TIMEOUT_MS=30000
EMAIL_SEND_TIMEOUT_MS=30000
